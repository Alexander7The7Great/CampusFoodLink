<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>CampusFoodLink – Vendor Menu</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: Arial, sans-serif;
      background: #fff;
      color: #111;
    }

    .header {
      text-align: center;
      padding: 14px;
      font-size: 28px;
      font-weight: bold;
    }

    .navbar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      border: 1px solid #ccc;
      padding: 10px 16px;
      margin: 0 10px;
    }

    .nav-left { display: flex; gap: 8px; }

    .nav-btn {
      background: #e8d9a8;
      border: 1px solid #bbb;
      padding: 8px 14px;
      font-size: 13px;
      cursor: pointer;
    }

    .nav-btn:hover { background: #d4c48e; }

    .nav-center {
      font-size: 20px;
      font-weight: bold;
    }

    .nav-right {
      display: flex;
      gap: 8px;
      align-items: center;
    }

    .balance-box {
      background: #e8d9a8;
      border: 1px solid #bbb;
      padding: 8px 14px;
      font-size: 13px;
      text-align: center;
    }

    .vendor-info {
      margin: 12px 10px 0;
      padding: 10px 16px;
      font-size: 13px;
      line-height: 1.8;
      color: #333;
    }

    .main {
      display: flex;
      gap: 0;
      margin: 10px;
      border: 1px solid #ccc;
    }

    .menu-section {
      flex: 2;
      border-right: 1px solid #ccc;
      padding: 16px;
    }

    .menu-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
    }

    .menu-card {
      border: 1px solid #ccc;
      padding: 10px;
      display: flex;
      flex-direction: column;
      gap: 4px;
      font-size: 13px;
      color: #444;
    }

    .menu-card button {
      align-self: flex-end;
      margin-top: 6px;
      background: #e8d9a8;
      border: 1px solid #bbb;
      padding: 4px 10px;
      font-size: 12px;
      cursor: pointer;
    }

    .menu-card button:hover { background: #d4c48e; }

    .order-section {
      flex: 1;
      padding: 16px;
    }

    .order-section h3 {
      font-size: 15px;
      font-weight: normal;
      margin-bottom: 12px;
    }

    .order-box {
      border: 1px solid #ccc;
      padding: 12px;
      font-size: 13px;
      color: #444;
      line-height: 2;
    }

    .order-item {
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .remove-btn {
      color: red;
      background: none;
      border: none;
      font-size: 14px;
      cursor: pointer;
    }

    .order-total {
      margin-top: 8px;
      font-weight: bold;
      font-size: 13px;
    }

    .submit-btn {
      width: 100%;
      margin-top: 12px;
      background: #e8d9a8;
      border: 1px solid #bbb;
      padding: 7px;
      font-size: 13px;
      cursor: pointer;
      text-align: right;
    }

    .submit-btn:hover { background: #d4c48e; }

    /* Hamburger */
    .hamburger {
      position: fixed;
      top: 14px;
      right: 16px;
      cursor: pointer;
      font-size: 22px;
      z-index: 100;
    }

    .dropdown {
      display: none;
      position: fixed;
      top: 44px;
      right: 16px;
      background: #fff;
      border: 1px solid #ccc;
      z-index: 100;
      min-width: 180px;
    }

    .dropdown a {
      display: block;
      padding: 10px 16px;
      font-size: 13px;
      text-decoration: none;
      color: #111;
      border-bottom: 1px solid #eee;
    }

    .dropdown a:hover { background: #e8d9a8; }
  </style>
</head>
<body>

  <div class="hamburger" onclick="toggleMenu()">&#9776;</div>
  <div class="dropdown" id="navMenu">
    <a href="login.html">Login</a>
    <a href="student-home.html">Student Home</a>
    <a href="vendor-menu.html">Vendor Menu</a>
    <a href="vendor-home.html">Vendor Home</a>
    <a href="menu-management.html">Menu Management</a>
  </div>

  <div class="header">CampusFoodLink</div>



  <div class="navbar">
    <div class="nav-left">
      <button class="nav-btn" onclick="window.location.href='/student/home'">Home</button>
      <button class="nav-btn" onclick="window.location.href='orderhistory'">Order History</button>
    </div>
    <div class="nav-center"><%= vendorMenu.vendor_name %> Menu</div>
    <div class="nav-right">
      <div class="balance-box">
        Meal Plan Balance<br/>
        $<%= balance.toFixed(2) %>
      </div>
          <form action="/logout?_method=DELETE" method="POST">
	        <button class="nav-btn" type="submit">Log Out</button>
	      </form>
    </div>
  </div>



  <div class="vendor-info">
    <p><%= vendorMenu.vendor_name %></p>
    <p><%= vendorMenu.vendor_description %></p>
    <p>Estimated prep time: 9 minutes</p>
  </div>



  <div class="main">
    <div class="menu-section">
      <div class="menu-grid">
          <!--Pull each item in the menu of the current vendor(vendor_id) from menu_item()-->
            <% vendorMenu.menuItems.forEach(item => { %>
            <div class="menu-card">
              <p><%= item.food_name %></p>
              <p><%= item.food_description %></p>
              <p>$<%= item.price.toFixed(2) %></p>
              <button>Add to Cart</button>
            </div>
            <% }) %>
      </div>
    </div>



    <div class="order-section">
      <h3>Your Order</h3>
      <div class="order-box">
        <div class="order-item">
          <span>-Food Name- x 1 - -Food Price-</span>
          <button class="remove-btn" style="color: red">X</button>
        </div>
        <div class="order-item">
          <span>-Food Name- x 3 - -Food Price-</span>
          <button class="remove-btn" style="color: red">X</button>
        </div>
        <div class="order-total">Total = $10.00</div>
        <p style="font-size:12px; margin-top:6px;">Available Meal Plan = -Balance-</p>
      </div>
      <button class="submit-btn" onclick="window.location.href='student-home.html'">Submit Order</button>
    </div>
  </div>



  <script>
    function toggleMenu() {
      const menu = document.getElementById('navMenu');
      menu.style.display = menu.style.display === 'block' ? 'none' : 'block';
    }
  </script>

</body>
</html>