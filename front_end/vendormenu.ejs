<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>CampusFoodLink – Vendor Menu</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: Arial, sans-serif;
      background: #fff;
      color: #111;
    }

    .header {
      text-align: center;
      padding: 14px;
      font-size: 28px;
      font-weight: bold;
    }

    .navbar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      border: 1px solid #ccc;
      padding: 10px 16px;
      margin: 0 10px;
    }

    .nav-left { display: flex; gap: 8px; }

    .nav-btn {
      background: #e8d9a8;
      border: 1px solid #bbb;
      padding: 8px 14px;
      font-size: 13px;
      cursor: pointer;
    }

    .nav-btn:hover { background: #d4c48e; }

    .nav-center {
      font-size: 20px;
      font-weight: bold;
    }

    .nav-right {
      display: flex;
      gap: 8px;
      align-items: center;
    }

    .balance-box {
      background: #e8d9a8;
      border: 1px solid #bbb;
      padding: 8px 14px;
      font-size: 13px;
      text-align: center;
    }

    .vendor-info {
      margin: 12px 10px 0;
      padding: 10px 16px;
      font-size: 13px;
      line-height: 1.8;
      color: #333;
    }

    .main {
      display: flex;
      gap: 0;
      margin: 10px;
      border: 1px solid #ccc;
    }

    .menu-section {
      flex: 2;
      border-right: 1px solid #ccc;
      padding: 16px;
    }

    .menu-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
    }

    .menu-card {
      border: 1px solid #ccc;
      padding: 10px;
      display: flex;
      flex-direction: column;
      gap: 4px;
      font-size: 13px;
      color: #444;
    }

    .menu-card button {
      align-self: flex-end;
      margin-top: 6px;
      background: #e8d9a8;
      border: 1px solid #bbb;
      padding: 4px 10px;
      font-size: 12px;
      cursor: pointer;
    }

    .menu-card button:hover { background: #d4c48e; }

    .order-section {
      flex: 1;
      padding: 16px;
    }

    .order-section h3 {
      font-size: 15px;
      font-weight: normal;
      margin-bottom: 12px;
    }

    .order-box {
      border: 1px solid #ccc;
      padding: 12px;
      font-size: 13px;
      color: #444;
      line-height: 2;
    }

    .order-item {
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .remove-btn {
      color: red;
      background: none;
      border: none;
      font-size: 14px;
      cursor: pointer;
    }

    .order-total {
      margin-top: 8px;
      font-weight: bold;
      font-size: 13px;
    }

    .submit-btn {
      width: 100%;
      margin-top: 12px;
      background: #e8d9a8;
      border: 1px solid #bbb;
      padding: 7px;
      font-size: 13px;
      cursor: pointer;
      text-align: right;
    }

    .submit-btn:hover { background: #d4c48e; }

    /* Hamburger */
    .hamburger {
      position: fixed;
      top: 14px;
      right: 16px;
      cursor: pointer;
      font-size: 22px;
      z-index: 100;
    }

    .dropdown {
      display: none;
      position: fixed;
      top: 44px;
      right: 16px;
      background: #fff;
      border: 1px solid #ccc;
      z-index: 100;
      min-width: 180px;
    }

    .dropdown a {
      display: block;
      padding: 10px 16px;
      font-size: 13px;
      text-decoration: none;
      color: #111;
      border-bottom: 1px solid #eee;
    }

    .dropdown a:hover { background: #e8d9a8; }
  </style>
</head>
<body>

  <div class="hamburger" onclick="toggleMenu()">&#9776;</div>
  <div class="dropdown" id="navMenu">
    <a href="login.html">Login</a>
    <a href="student-home.html">Student Home</a>
    <a href="vendor-menu.html">Vendor Menu</a>
    <a href="vendor-home.html">Vendor Home</a>
    <a href="menu-management.html">Menu Management</a>
  </div>

  <div class="header">CampusFoodLink</div>



  <div class="navbar">
    <div class="nav-left">
      <button class="nav-btn" onclick="window.location.href='/student/home'">Home</button>
      <button class="nav-btn" onclick="window.location.href='/orderhistory'">Order History</button>
    </div>
    <div class="nav-center"><%= vendorMenu.vendor_name %> Menu</div>
    <div class="nav-right">
      <div class="balance-box">
        Meal Plan Balance<br/>
        $<%= balance.toFixed(2) %>
      </div>
          <form action="/logout?_method=DELETE" method="POST">
	        <button class="nav-btn" type="submit">Log Out</button>
	      </form>
    </div>
  </div>



  <div class="vendor-info">
    <p><%= vendorMenu.vendor_name %></p>
    <p><%= vendorMenu.vendor_description %></p>
    <p>Estimated prep time: 9 minutes</p>
  </div>



  <div class="main">
    <div class="menu-section">
      <div class="menu-grid">
          <!--Pull each item in the menu of the current vendor(vendor_id) from menu_item()-->
            <% vendorMenu.menuItems.forEach(item => { %>
            <div class="menu-card">
              <p><%= item.food_name %></p>
              <p><%= item.food_description %></p>
              <p>$<%= item.price.toFixed(2) %></p>
              <button onclick="addToOrder('<%= item.item_id %>', '<%= item.food_name %>', <%= item.price %>)">Add to Cart</button>
            </div>
            <% }) %>
      </div>
    </div>



    <div class="order-section">
      <h3>Your Order</h3>
      <div class="order-box">
        <div id="order-items">
          <p style="color:#999; font-size:13px;">No items in cart.</p>
        </div>
        <div class="order-total" id="order-total">Total = $0.00</div>
        <p style="font-size:12px; margin-top:6px;">Available Meal Plan = $<%= balance.toFixed(2) %> </p>
      </div>


        <!--Order submission that can post all the data from the order once the user clicks the button-->
      <form id="orderForm" action="/order" method="POST">
        <input type="hidden" name="vendorId" value="<%= vendorMenu.vendor_id %>" />
        <input type="hidden" name="orderTotal" id="orderTotalInput" />
        <input type="hidden" name="items" id="foodInput" />
        <button id="orderSubmitBtn" class="submit-btn" type="submit" style="display:none;">Submit Order</button>
      </form>
    </div>
  </div>



  <script>
  //create client side order to store what they add to it
    mealPlanBal = <%= balance %>;
    const order = [];

    //add items to the cart, with their id, price, and the amount of them that they have added
    function addToOrder(id, food, price) {
        
        //check to see if the item is already in the order to increase the amount of it
        const inOrder = order.find(item => item.id === id);
        if (inOrder) {
            inOrder.amount++
        } else {
        //add 1 if it isnt already in the order
        order.push({id, food, price, amount: 1})
        }

        //call the display order function to reflect all the changes immediately to the user
        displayOrder();
    }


    //remove an item from the order
    function removeFromOrder(id) {

        //find the position of the item in the order
        const i = order.findIndex(item => item.id ===id);

            //check to see if there is more than one of the item so it can be taken off
            if (order[i].amount > 1) {
            order[i].amount--;

            //if there is only one on the order it should be fully taken off of it
            } else {
              order.splice(i, 1);
            }

        displayOrder();
    }

    //show the order if there are items in it
    function displayOrder() {
        
        //store the id for the targeted sections for order
        const box = document.getElementById('order-items');
        const totalBox = document.getElementById('order-total');
        const orderSubmit = document.getElementById('orderSubmitBtn');

        //check to see if there is anything in the cart
        // if it is empty show that to the user
        if (order.length === 0) {
        box.innerHTML = '<p style="color:#999; font-size:13px;">No items in cart.</p>';

        //show an 0 total when it is empty as well
        totalBox.textContent = 'Total = $0.00';
        orderSubmit.style.display = 'none';
        return;
     }

        //in the section for the order map each added item out in a new div for each
        //also calculate the total of each based on the amount added so far
        box.innerHTML = order.map(item => 
        `<div class="order-item">
            <span>${item.food} x${item.amount} — $${(item.price * item.amount).toFixed(2)}</span>
            <button class="remove-btn" onclick="removeFromOrder('${item.id}')">X</button>
            </div>`).join('');

        //add up the price of every item and the amount of them
        const total = order.reduce((sum, item) => sum + item.price * item.amount, 0);

        //let the user know when the order is over their balance
        if (total > mealPlanBal) {
            totalBox.textContent = `Total = $${total.toFixed(2)}. This is over your balanace`;
        } else { totalBox.textContent = `Total = $${total.toFixed(2)}`; }

        //disable the submit button once the order total goes over the current meal plan balance
        orderSubmit.style.display = (total > mealPlanBal) ? 'none' : 'block';
}

    //hamburger navigation menu opening and closing
    function toggleMenu() {
        const menu = document.getElementById('navMenu');
        menu.style.display = menu.style.display === 'block' ? 'none' : 'block';
    }

        //fill in the form with the order information, and add up the total for the final submission of the order
        document.getElementById('orderForm').addEventListener('submit', function () {

        //get the total by summing up the total of the item based on the amount of each of them until they are all added to the total
        const total = order.reduce((sum, item) => sum + item.price * item.amount, 0);
            document.getElementById('orderTotalInput').value = total.toFixed(2);

            if (total > mealPlanBal) {
                event.preventDefault();
                
            }
        //map the id and amount of an item to an array to be pushed into the order item table alongside the associated order

        const items = order.map(item => ({ id: item.id, amount: item.amount }));


        //store the food that was submitted from the order as json so rows can be created for each of them in the order item table
        document.getElementById('foodInput').value = JSON.stringify(items);
    });
  </script>

</body>
</html>