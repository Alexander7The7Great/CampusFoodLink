<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>CampusFoodLink - Order History</title>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: Arial, sans-serif;
            background: #fff;
            color: #111;
        }

        .header {
            text-align: center;
            padding: 14px;
            font-size: 28px;
            font-weight: bold;
        }

        .navbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            border: 1px solid #ccc;
            padding: 10px 16px;
            margin: 0 10px;
        }

        .nav-btn {
            background: #e8d9a8;
            border: 1px solid #bbb;
            padding: 8px 14px;
            font-size: 13px;
            cursor: pointer;
        }

        .nav-btn:hover { background: #d4c48e; }

        .nav-center {
            font-size: 20px;
            font-weight: bold;
        }

        .nav-right {
            display: flex;
            gap: 8px;
            align-items: center;
        }

        .balance-box {
            background: #e8d9a8;
            border: 1px solid #bbb;
            padding: 8px 14px;
            font-size: 13px;
            text-align: center;
        }

        .main {
            margin: 10px;
            border: 1px solid #ccc;
            padding: 16px;
        }

        .order-card {
            border: 1px solid #ccc;
            padding: 12px;
            margin-bottom: 12px;
            background: #f9f9f9;
        }

        .order-header {
            display: flex;
            justify-content: space-between;
            font-size: 13px;
            font-weight: bold;
            margin-bottom: 8px;
            padding-bottom: 6px;
            border-bottom: 1px solid #ddd;
        }

        .order-items {
            font-size: 13px;
            color: #444;
            margin-bottom: 8px;
        }

        .order-footer {
            display: flex;
            justify-content: space-between;
            font-size: 13px;
            color: #444;
            padding-top: 6px;
            border-top: 1px solid #ddd;
        }

        .no-orders {
            text-align: center;
            color: #999;
            font-size: 13px;
            padding: 20px;
        }

        /* Hamburger */
        .hamburger {
            position: fixed;
            top: 14px;
            right: 16px;
            cursor: pointer;
            font-size: 22px;
            z-index: 100;
        }

        .dropdown {
            display: none;
            position: fixed;
            top: 44px;
            right: 16px;
            background: #fff;
            border: 1px solid #ccc;
            z-index: 100;
            min-width: 180px;
        }

        .dropdown a {
            display: block;
            padding: 10px 16px;
            font-size: 13px;
            text-decoration: none;
            color: #111;
            border-bottom: 1px solid #eee;
        }

        .dropdown a:hover { background: #e8d9a8; }
    </style>
</head>
<body>

    <div class="hamburger" onclick="toggleMenu()">&#9776;</div>
    <div class="dropdown" id="navMenu">
        <a href="/student/home">Student Home</a>
        <a href="/orderhistory">Order History</a>
    </div>

    <div class="header">CampusFoodLink</div>

    <div class="navbar">
        <div class="nav-left">
            <button class="nav-btn" onclick="window.location.href='/student/home'">Home</button>
        </div>
        <div class="nav-center">Order History</div>
        <div class="nav-right">
            <div class="balance-box">
                Meal Plan Balance: $<%= balance.toFixed(2) %>
            </div>
            <form action="/logout?_method=DELETE" method="POST">
                <button class="nav-btn" type="submit">Log Out</button>
            </form>
        </div>
    </div>




    <div class="main">

        <% if (orders.length === 0) { %>
            <p class="no-orders">No order history found.</p>
        <% } else { %>
            <% orders.forEach(order => { %>
            <div class="order-card">

                <div class="order-header">
                    <span>Order #<%= order.order_id %> — <%= order.vendor_name %></span>
                    <span><%= new Date(order.time_created).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %></span>
                </div>

                <div class="order-items">
                    <!-- Loop through each food item in the order -->
                    <% order.food.forEach(item => { %>
                        <p><%= item.food_name %> x<%= item.amount %> — $<%= (item.price * item.amount).toFixed(2) %></p>
                    <% }) %>
                </div>

                <div class="order-footer">
                    <span>Total: $<%= order.order_total.toFixed(2) %></span>
                    <span>Status: <%= order.status %></span>
                </div>

            </div>
            <% }) %>
        <% } %>

    </div>

    <script>
        function toggleMenu() {
            const menu = document.getElementById('navMenu');
            menu.style.display = menu.style.display === 'block' ? 'none' : 'block';
        }
    </script>

</body>
</html>