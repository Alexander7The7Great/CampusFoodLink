<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>CampusFoodLink - Login</title>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: Arial, sans-serif;
            background: #fff;
            color: #111;
        }

        .header {
            background: #d9c9a0;
            text-align: center;
            padding: 14px;
            font-size: 28px;
            font-weight: bold;
            border-bottom: 1px solid #bbb;
        }

        .page-label {
            text-align: center;
            font-size: 18px;
            padding: 10px;
            border: 1px solid #ccc;
            margin: 0 60px;
        }

        .main {
            display: flex;
            justify-content: center;
            align-items: flex-start;
            padding: 30px 20px;
        }

        .login-box {
            border: 1px solid #ccc;
            width: 340px;
            padding: 20px 24px 30px;
        }

        .logo-area {
            height: 60px;
            border-bottom: 1px solid #ccc;
            margin-bottom: 14px;
        }

        .login-box h2 {
            font-size: 16px;
            font-weight: normal;
            margin-bottom: 12px;
        }

        .login-box input {
            width: 100%;
            padding: 6px 8px;
            margin-bottom: 8px;
            border: 1px solid #bbb;
            font-size: 14px;
            background: #f5f5f5;
        }

        .btn-row {
            display: flex;
            gap: 8px;
            margin-top: 4px;
        }

        .btn {
            flex: 1;
            padding: 7px;
            font-size: 13px;
            background: #e8d9a8;
            border: 1px solid #bbb;
            cursor: pointer;
        }

        .btn:hover { background: #d4c48e; }

        /* Hamburger */
        .hamburger {
            position: fixed;
            top: 14px;
            right: 16px;
            cursor: pointer;
            font-size: 22px;
            z-index: 100;
        }

        .dropdown {
            display: none;
            position: fixed;
            top: 44px;
            right: 16px;
            background: #fff;
            border: 1px solid #ccc;
            z-index: 100;
            min-width: 180px;
        }

        .dropdown a {
            display: block;
            padding: 10px 16px;
            font-size: 13px;
            text-decoration: none;
            color: #111;
            border-bottom: 1px solid #eee;
        }

        .dropdown a:hover { background: #e8d9a8; }
    </style>
</head>
<body>


    <div class="hamburger" onclick="toggleMenu()">&#9776;</div>
    <div class="dropdown" id="navMenu">
        <a href="/login">Login</a>
        <a href="/register">Register</a>
        <a href="/">Index</a>
    </div>



    <div class="header">CampusFoodLink</div>
    <div class="page-label">Login Page</div>



    <div class="main">
        <div class="login-box">
            <div class="logo-area"></div>
            <h2>Sign in</h2>
            <% if (messages.error) {%>
            <%= messages.error %>
            <% } %>

            <form action="/login" method="POST">
                <input type="email" id="email" name="email" placeholder="Email" required="" />
                <input type="password" id="password" name="password" placeholder="Password" required="" />
                <div class="btn-row">
                    <button class="btn" type="submit">Sign in</button>

                    <button class="btn" onclick="window.location.href='/register'">Register</button>
                </div>
            </form>
        </div>
     </div>



    <script>
        function toggleMenu() {
            const menu = document.getElementById('navMenu');
            menu.style.display = menu.style.display === 'block' ? 'none' : 'block';
        }
    </script>

</body>
</html>