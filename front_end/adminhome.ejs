<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>CampusFoodLink – Admin Home</title>
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: Arial, sans-serif;
            background: #fff;
            color: #111;
        }

        .header {
            text-align: center;
            padding: 14px;
            font-size: 28px;
            font-weight: bold;
        }

        .navbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            border: 1px solid #ccc;
            padding: 10px 16px;
            margin: 0 10px;
        }

        .nav-btn {
            background: #e8d9a8;
            border: 1px solid #bbb;
            padding: 8px 14px;
            font-size: 13px;
            cursor: pointer;
        }

            .nav-btn:hover {
                background: #d4c48e;
            }

        .nav-center {
            font-size: 20px;
            font-weight: bold;
        }

        .nav-right {
            display: flex;
            gap: 8px;
            align-items: center;
        }

        .active-box {
            background: #e8d9a8;
            border: 1px solid #bbb;
            padding: 8px 14px;
            font-size: 13px;
            text-align: center;
        }

        .main {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 20px;
            margin: 10px;
            border: 1px solid #ccc;
            padding: 20px;
        }

        .vendor-section {
            width: 40%;
            padding: 10px;
            border-right: 1px solid #ccc;
        }

        .student-meal {
            width: 60%;
            padding: 10px;
        }

        .vendor-card,
        .student-card {
            border: 1px solid #ccc;
            padding: 10px;
            margin-bottom: 10px;
            background: #f9f9f9;
        }

        .fund-btn {
            background: #e8d9a8;
            border: 1px solid #bbb;
            padding: 3px 5px;
            font-size: 13px;
            cursor: pointer;
        }

        /* Hamburger */
        .hamburger {
            position: fixed;
            top: 14px;
            right: 16px;
            cursor: pointer;
            font-size: 22px;
            z-index: 100;
        }

        .dropdown {
            display: none;
            position: fixed;
            top: 44px;
            right: 16px;
            background: #fff;
            border: 1px solid #ccc;
            z-index: 100;
            min-width: 180px;
        }

            .dropdown a {
                display: block;
                padding: 10px 16px;
                font-size: 13px;
                text-decoration: none;
                color: #111;
                border-bottom: 1px solid #eee;
            }

                .dropdown a:hover {
                    background: #e8d9a8;
                }

    </style>
</head>
<body>

    <div class="hamburger" onclick="toggleMenu()">&#9776;</div>
    <div class="dropdown" id="navMenu">
        <a href="/accountmanagement">Account Management</a>
    </div>

    <div class="header">CampusFoodLink</div>



    <div class="navbar">
        <div class="nav-left">
            <button class="nav-btn" onclick="window.location.href='/accountmanagement'">Account Management</button>
        </div>
        <div class="nav-center">Admin Home</div>
        <div class="nav-right">
            <div class="active-box">
                Total Vendors: <%= vendors.length %>
            </div>
            <form action="/logout?_method=DELETE" method="POST">
                <button class="nav-btn" type="submit">Log Out</button>
            </form>
        </div>
    </div>



    <div class="main">
        <div class="vendor-section">
            <h3>Vendors</h3>
            <% vendorsAndStats.forEach(vendor => { %>
           <div class="vendor-card">
               <span><%= vendor.vendor_name %></span>
               <p>Prep Time: <%= vendor.prepTime.toFixed(2) %> Minutes</p>
           </div>
            <br />
            <% }) %>
            </div>


        <div class="student-meal">
                <h3>Student Meal Plans</h3>
            <% students.forEach(student => { %>
            <div class="student-card">
                <p>Email: <%= student.email %> </p>
                <p>student id <%= student.Student_id %></p>
                <p>Meal plan Balance: $<%= student.meal_plan_balance.toFixed(2) %> </p>
                <form action="/admin/addbal" method="POST">
                    <input type="hidden" name="studentId" value="<%= student.Student_id %>">
                    <input type="number" step=".05" min="0" name="amount" placeholder="Example: 2.50" required>
                    <button type="submit" class="fund-btn">Add Funds</button>
                </form>
             </div>
            <br />
            <% }) %>
        </div>
    </div>


    <script>
    function toggleMenu() {
      const menu = document.getElementById('navMenu');
      menu.style.display = menu.style.display === 'block' ? 'none' : 'block';
    }
    </script>

</body>
</html>