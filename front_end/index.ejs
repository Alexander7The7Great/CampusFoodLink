<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>CampusFoodLink - Start Page</title>
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: Arial, sans-serif;
            background: #fff;
            color: #111;
        }

        .header {
            background: #fff;
            text-align: center;
            padding: 14px;
            font-size: 28px;
            font-weight: bold;
        }

        .navbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            border: 1px solid #ccc;
            padding: 10px 16px;
            margin: 0 10px;
        }

        .nav-left {
            display: flex;
            gap: 8px;
        }

        .nav-btn {
            background: #e8d9a8;
            border: 1px solid #bbb;
            padding: 8px 14px;
            font-size: 13px;
            cursor: pointer;
        }

            .nav-btn:hover {
                background: #d4c48e;
            }

        .nav-center {
            font-size: 20px;
            font-weight: bold;
        }

        .nav-right {
            display: flex;
            gap: 8px;
            align-items: center;
        }

        .balance-box {
            background: #e8d9a8;
            border: 1px solid #bbb;
            padding: 8px 14px;
            font-size: 13px;
            text-align: center;
        }

        .main {
            display: flex;
            gap: 0;
            margin: 10px;
            border: 1px solid #ccc;
        }

        .vendors-section {
            flex: 2;
            border-right: 1px solid #ccc;
            padding: 16px;
        }

            .vendors-section h3 {
                text-align: center;
                font-size: 15px;
                font-weight: normal;
                margin-bottom: 12px;
            }

        .vendor-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
        }

        .vendor-card {
            border: 1px solid #ccc;
            padding: 12px;
            display: flex;
            flex-direction: column;
            gap: 4px;
        }

            .vendor-card p {
                font-size: 13px;
                color: #444;
            }

            .vendor-card button {
                align-self: flex-end;
                margin-top: 8px;
                background: #e8d9a8;
                border: 1px solid #bbb;
                padding: 4px 10px;
                font-size: 12px;
                cursor: pointer;
            }

                .vendor-card button:hover {
                    background: #d4c48e;
                }

        .order-section {
            flex: 1;
            padding: 16px;
        }

            .order-section h3 {
                text-align: center;
                font-size: 15px;
                font-weight: normal;
                margin-bottom: 12px;
            }

        .order-box {
            border: 1px solid #ccc;
            padding: 12px;
            font-size: 13px;
            color: #444;
            line-height: 1.8;
        }

        /* Hamburger */
        .hamburger {
            position: fixed;
            top: 14px;
            right: 16px;
            cursor: pointer;
            font-size: 22px;
            z-index: 100;
        }

        .dropdown {
            display: none;
            position: fixed;
            top: 44px;
            right: 16px;
            background: #fff;
            border: 1px solid #ccc;
            z-index: 100;
            min-width: 180px;
        }

            .dropdown a {
                display: block;
                padding: 10px 16px;
                font-size: 13px;
                text-decoration: none;
                color: #111;
                border-bottom: 1px solid #eee;
            }

                .dropdown a:hover {
                    background: #e8d9a8;
                }
    </style>
</head>
<body>

    <div class="hamburger" onclick="toggleMenu()">&#9776;</div>
    <div class="dropdown" id="navMenu">
        <a href="/login">Login Page</a>
        <a href="/register">Register Page</a>
    </div>

    <div class="header">CampusFoodLink</div>



    <div class="navbar">
        <% if (user) { %>
        <div class="nav-left">
            <button class="nav-btn" onclick="window.location.href='/<%= user.role_name %>/home'">Go to Home</button>
        </div>
        <div class="nav-center">Welcome to CampusFoodLink</div>
        <div class="nav-right">
            <form action="/logout?_method=DELETE" method="POST">
                <button class="nav-btn" type="submit">Log Out</button>
            </form>
        </div>
        <% } else { %>
        <div class="nav-left">
        </div>
        <div class="nav-center">Welcome to CampusFoodLink</div>
        <div class="nav-right">
            <button class="nav-btn" onclick="window.location.href='/login'">Log in</button>
        </div>
        <% } %>
    </div>



    <div class="main">

    </div>

    <script>
			function toggleMenu() {
			const menu = document.getElementById('navMenu');
			menu.style.display = menu.style.display === 'block' ? 'none' : 'block';
			}
    </script>

</body>
</html>