<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
		<title>CampusFoodLink - Student Home</title>
		<style>
			* { box-sizing: border-box; margin: 0; padding: 0; }

			body {
			font-family: Arial, sans-serif;
			background: #fff;
			color: #111;
			}

			.header {
			background: #fff;
			text-align: center;
			padding: 14px;
			font-size: 28px;
			font-weight: bold;
			}

			.navbar {
			display: flex;
			justify-content: space-between;
			align-items: center;
			border: 1px solid #ccc;
			padding: 10px 16px;
			margin: 0 10px;
			}

			.nav-left { display: flex; gap: 8px; }

			.nav-btn {
			background: #e8d9a8;
			border: 1px solid #bbb;
			padding: 8px 14px;
			font-size: 13px;
			cursor: pointer;
			}

			.nav-btn:hover { background: #d4c48e; }

			.nav-center {
			font-size: 20px;
			font-weight: bold;
			}

			.nav-right {
			display: flex;
			gap: 8px;
			align-items: center;
			}

			.balance-box {
			background: #e8d9a8;
			border: 1px solid #bbb;
			padding: 8px 14px;
			font-size: 13px;
			text-align: center;
			}

			.main {
			display: flex;
			gap: 0;
			margin: 10px;
			border: 1px solid #ccc;
			}

			.vendors-section {
			flex: 2;
			border-right: 1px solid #ccc;
			padding: 16px;
			}

			.vendors-section h3 {
			text-align: center;
			font-size: 15px;
			font-weight: normal;
			margin-bottom: 12px;
			}

			.vendor-grid {
			display: grid;
			grid-template-columns: 1fr 1fr;
			gap: 12px;
			}

			.vendor-card {
			border: 1px solid #ccc;
			padding: 12px;
			display: flex;
			flex-direction: column;
			gap: 4px;
			}

			.vendor-card p {
			font-size: 13px;
			color: #444;
			}

			.vendor-card button {
			align-self: flex-end;
			margin-top: 8px;
			background: #e8d9a8;
			border: 1px solid #bbb;
			padding: 4px 10px;
			font-size: 12px;
			cursor: pointer;
			}

			.vendor-card button:hover { background: #d4c48e; }

			.order-section {
			flex: 1;
			padding: 16px;
			}

			.order-section h3 {
			text-align: center;
			font-size: 15px;
			font-weight: normal;
			margin-bottom: 12px;
			}

			.order-box {
			border: 1px solid #ccc;
			padding: 12px;
			font-size: 13px;
			color: #444;
			line-height: 1.8;
			}

			/* Hamburger */
			.hamburger {
			position: fixed;
			top: 14px;
			right: 16px;
			cursor: pointer;
			font-size: 22px;
			z-index: 100;
			}

			.dropdown {
			display: none;
			position: fixed;
			top: 44px;
			right: 16px;
			background: #fff;
			border: 1px solid #ccc;
			z-index: 100;
			min-width: 180px;
			}

			.dropdown a {
			display: block;
			padding: 10px 16px;
			font-size: 13px;
			text-decoration: none;
			color: #111;
			border-bottom: 1px solid #eee;
			}

			.dropdown a:hover { background: #e8d9a8; }
		</style>
	</head>
	<body>

		<div class="hamburger" onclick="toggleMenu()">&#9776;</div>
		<div class="dropdown" id="navMenu">
			<a href="/student/home">Student Home</a>
			<a href="/orderhistory">Order History</a>
		</div>

		<div class="header">CampusFoodLink</div>

		
		
		<div class="navbar">
			<div class="nav-left">
				<button class="nav-btn" onclick="window.location.href='orderhistory.html'">Order History</button>
			</div>
			<div class="nav-center">Student Home</div>
			<div class="nav-right">
				<div class="balance-box">
					<!--Access the student_profile(meal_plan_balance) to show the user their current balance-->
					Meal Plan Balance<br />
					$<%= balance.toFixed(2) %>
				</div>
				<form action="/logout?_method=DELETE" method="POST">
					<button class="nav-btn" type="submit">Log Out</button>
				</form>
			</div>
		</div>

		
		
		<div class="main">
			<div class="vendors-section">
				<h3>Vendors</h3>
				<div class="vendor-grid">
					<!--Display each vendor as their own card from the vendor(vendor_id, vendor_name, vendor_description) table-->
					<% vendors.forEach(vendor => { %>
					<div class="vendor-card">
						<h2>
							<!--Display the name of each vendor-->
							<%= vendor.vendor_name %>
						</h2>
						<p>
							<!--Display the description of each vendor-->
							<%= vendor.vendor_description %>
						</p>

						<!--Button that will route the user to the page of the associated vendor based on the id-->
						<button onclick="window.location.href='/vendormenu/<%- vendor.vendor_id %>'">View Menu</button>
					</div>
					<% }) %>
				</div>
			</div>

			
			
			<div class="order-section">
				<!-- Pull the information from the database to show the current active orders for
                                            the user based on who is logged in from the order(Order_id, order_total), vendor(vendor_id, vendor_name)
                                            and current status from order_status_history(order_id, status)-->
				<h3>Active Order</h3>
				<div class="order-box">

					<!--When there are no orders for the user it will let the user know they do not have any-->
				<% if (activeOrders.length === 0) { %>
					<p style="color:#999;">No active orders.</p>
				<% } else { %>
					<!--When the user does have active order though each will be pulled and displayed-->
					<% activeOrders.forEach(order => { %>

					<!--The order id and the vendor that it is with will be shown-->
					<p>Order #<%= order.order_id %> - <%= order.vendor_name %></p>

					<!--The total cost of the order and what its current status will also be displayed directly in the section-->
					<p>Total: $<%= order.order_total.toFixed(2) %></p>
					<p>Order Status: <%= order.status %></p>
					<hr/>
					<% }) %>
					<% } %>
					<!--Might have to edit this to turn into a collapsible menu in case the user has a lot of orders that 
						go far down the page-->
				</div>
			</div>
		</div>

		<script>
			function toggleMenu() {
			const menu = document.getElementById('navMenu');
			menu.style.display = menu.style.display === 'block' ? 'none' : 'block';
			}
		</script>

	</body>
</html>